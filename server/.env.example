# ──────────────────────────────────────
# GumBear Server Configuration
# ──────────────────────────────────────

# API key for client authentication (REQUIRED — change this!)
API_KEY=change-me-to-a-secure-random-string

# Control server port (clients connect here)
CONTROL_PORT=4444

# HTTP proxy port (subdomain routing)
HTTP_PORT=80

# Domain for subdomain routing
DOMAIN=gumbear.alora.baby

# Random port range for TCP tunnels
PORT_RANGE_MIN=10000
PORT_RANGE_MAX=59999

# Log level: debug, info, warn, error
LOG_LEVEL=info
